<%- include('../partials/header') %>
<% const basePath = currentPath.startsWith('/manage') ? '/manage/projects' : '/admin/projects'; %>

<div class="page-header">
  <h1>Manage Projects</h1>
</div>

<div class="form-card" id="project-form-card" style="display:none;">
  <h2 id="form-title">Add Project</h2>
  <div id="archived-notice" class="alert alert-error" style="display:none;">This project is archived. Reactivate it to make changes.</div>
  <form action="<%= basePath %>" method="POST" id="project-form">
    <input type="hidden" id="edit-id" name="edit_id" value="">
    <div class="form-row">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Project name">
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <input type="text" id="description" name="description" placeholder="Brief description">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="category_id">Category</label>
        <select id="category_id" name="category_id">
          <option value="">Uncategorized</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="default_assignee_id">Default Assignee</label>
        <select id="default_assignee_id" name="default_assignee_id">
          <option value="">Unassigned</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.display_name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="homepage_url">Homepage URL</label>
        <input type="text" id="homepage_url" name="homepage_url" placeholder="https://example.com">
      </div>
      <div class="form-group">
        <label for="github_url">GitHub Repo</label>
        <div class="input-group">
          <span class="input-group-prefix">https://github.com/</span>
          <input type="text" id="github_url" name="github_url" placeholder="org/repo">
        </div>
      </div>
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" id="project_active" name="project_active" checked> <span class="checkbox-text">Active</span>
      </label>
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" id="internally_visible" name="internally_visible" checked> <span class="checkbox-text">Internally visible</span>
      </label>
    </div>
    <div class="form-group" id="public-group">
      <label class="checkbox-label">
        <input type="checkbox" id="public" name="public" checked> <span class="checkbox-text">Publicly visible</span>
      </label>
    </div>
    <div class="form-actions" id="active-actions">
      <button type="submit" class="btn btn-primary" id="form-submit">Create Project</button>
      <button type="button" class="btn btn-ghost" id="cancel-edit">Cancel</button>
      <button type="button" class="btn btn-ghost" id="archive-btn" style="display:none;">Archive</button>
      <button type="button" class="btn btn-danger" id="delete-project-btn" style="display:none;">Delete</button>
    </div>
  </form>
  <div class="form-actions" id="archived-actions" style="display:none;">
    <form id="reactivate-form" method="POST" class="inline-form">
      <button type="submit" class="btn btn-primary">Reactivate</button>
    </form>
    <button type="button" class="btn btn-ghost" id="cancel-archived">Cancel</button>
    <button type="button" class="btn btn-danger" id="delete-archived-btn">Delete</button>
  </div>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th>Default Assignee</th>
      <th>Visibility</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% projects.forEach(project => { %>
      <tr class="<%= project.active ? '' : 'row-muted' %>" style="cursor:pointer;"
          data-project-id="<%= project.id %>"
          data-name="<%= project.name %>"
          data-description="<%= project.description || '' %>"
          data-category-id="<%= project.category_id || '' %>"
          data-default-assignee-id="<%= project.default_assignee_id || '' %>"
          data-homepage-url="<%= project.homepage_url || '' %>"
          data-github-url="<%= project.github_url || '' %>"
          data-internally-visible="<%= project.internally_visible %>"
          data-public="<%= project.public %>"
          data-active="<%= project.active %>">
        <td><%= project.name %></td>
        <td><%= project.category_name || '—' %></td>
        <td><%= project.assignee_name || '—' %></td>
        <td>
          <span class="badge badge-status-<%= project.internally_visible ? 'open' : 'closed' %>"><%= project.internally_visible ? 'Internal' : 'Hidden' %></span>
          <% if (project.internally_visible && project.public) { %><span class="badge badge-status-open">Public</span><% } %>
        </td>
        <td><span class="badge badge-status-<%= project.active ? 'open' : 'closed' %>"><%= project.active ? 'Active' : 'Archived' %></span></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<div style="margin-top:1rem;">
  <button type="button" class="btn btn-primary" id="add-project-btn">Add Project</button>
</div>

<div id="delete-project-modal" class="modal-overlay" style="display:none;">
  <div class="modal">
    <h3>Delete Project</h3>
    <p>Are you sure you want to delete <strong id="delete-project-name"></strong>? This cannot be undone.</p>
    <form id="delete-project-form" method="POST">
      <div class="modal-actions">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <button type="button" class="btn btn-ghost" id="close-delete-modal">Cancel</button>
      </div>
    </form>
  </div>
</div>

<div id="archive-project-modal" class="modal-overlay" style="display:none;">
  <div class="modal">
    <h3>Archive Project</h3>
    <p>Are you sure you want to archive <strong id="archive-project-name"></strong>?</p>
    <form id="archive-project-form" method="POST">
      <div class="modal-actions">
        <button type="submit" class="btn btn-primary">Yes, Archive</button>
        <button type="button" class="btn btn-ghost" id="close-archive-modal">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/admin-projects.js" data-base-path="<%= basePath %>"></script>

<%- include('../partials/footer') %>
