<%- include('../partials/header') %>

<div class="page-header">
  <h1>Manage Projects</h1>
</div>

<div class="form-card">
  <h2>Add Project</h2>
  <form action="/admin/projects" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Project name">
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <input type="text" id="description" name="description" placeholder="Brief description">
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Create Project</button>
  </form>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Slug</th>
      <th>Status</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% projects.forEach(project => { %>
      <tr class="<%= project.active ? '' : 'row-muted' %>">
        <td><%= project.name %></td>
        <td class="text-muted"><%= project.slug %></td>
        <td><span class="badge badge-status-<%= project.active ? 'open' : 'closed' %>"><%= project.active ? 'Active' : 'Archived' %></span></td>
        <td><%= project.created_at.split('T')[0] %></td>
        <td class="actions">
          <form action="/admin/projects/<%= project.id %>/toggle" method="POST" class="inline-form">
            <button type="submit" class="btn btn-sm btn-ghost"><%= project.active ? 'Archive' : 'Restore' %></button>
          </form>
          <form action="/admin/projects/<%= project.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Delete this project?')">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
