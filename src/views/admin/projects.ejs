<%- include('../partials/header') %>

<div class="page-header">
  <h1>Manage Projects</h1>
</div>

<div class="form-card">
  <h2>Add Project</h2>
  <form action="/admin/projects" method="POST">
    <div class="form-row">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Project name">
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <input type="text" id="description" name="description" placeholder="Brief description">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="category_id">Category</label>
        <select id="category_id" name="category_id">
          <option value="">Uncategorized</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="default_assignee_id">Default Assignee</label>
        <select id="default_assignee_id" name="default_assignee_id">
          <option value="">Unassigned</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.display_name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="public" checked> Publicly visible
      </label>
    </div>
    <button type="submit" class="btn btn-primary">Create Project</button>
  </form>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Category</th>
      <th>Default Assignee</th>
      <th>Visibility</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% projects.forEach(project => { %>
      <tr class="<%= project.active ? '' : 'row-muted' %>">
        <td><%= project.name %></td>
        <td><%= project.category_name || '—' %></td>
        <td><%= project.assignee_name || '—' %></td>
        <td><span class="badge badge-status-<%= project.public ? 'open' : 'closed' %>"><%= project.public ? 'Public' : 'Private' %></span></td>
        <td><span class="badge badge-status-<%= project.active ? 'open' : 'closed' %>"><%= project.active ? 'Active' : 'Archived' %></span></td>
        <td class="actions">
          <form action="/admin/projects/<%= project.id %>/visibility" method="POST" class="inline-form">
            <button type="submit" class="btn btn-sm btn-ghost"><%= project.public ? 'Make Private' : 'Make Public' %></button>
          </form>
          <form action="/admin/projects/<%= project.id %>/toggle" method="POST" class="inline-form">
            <button type="submit" class="btn btn-sm btn-ghost"><%= project.active ? 'Archive' : 'Restore' %></button>
          </form>
          <form action="/admin/projects/<%= project.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Delete this project?')">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
