<%- include('../partials/header') %>

<div class="page-header">
  <h1>Manage Users</h1>
</div>

<div class="form-card" id="user-form-card">
  <h2 id="form-title">Add User</h2>
  <form id="user-form" action="/admin/users" method="POST" autocomplete="off">
    <input type="hidden" id="edit-id" name="edit_id" value="">
    <div class="form-row">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autocomplete="off">
      </div>
      <div class="form-group">
        <label for="display_name">Display Name</label>
        <input type="text" id="display_name" name="display_name" required autocomplete="off">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="off">
      </div>
      <div class="form-group" id="password-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="new-password">
      </div>
    </div>
    <div class="form-group">
      <label for="role">Role</label>
      <select id="role" name="role">
        <option value="user">User</option>
        <option value="admin">Admin</option>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="form-submit">Create User</button>
      <button type="button" class="btn btn-danger" id="cancel-edit" style="display:none;">Cancel</button>
    </div>
  </form>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Username</th>
      <th>Display Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(user => { %>
      <tr class="<%= user.active ? '' : 'row-muted' %>" style="cursor:pointer;"
          data-user-id="<%= user.id %>"
          data-username="<%= user.username %>"
          data-display-name="<%= user.display_name %>"
          data-email="<%= user.email %>"
          data-role="<%= user.role %>">
        <td><%= user.username %></td>
        <td><%= user.display_name %></td>
        <td><%= user.email %></td>
        <td><span class="badge"><%= user.role %></span></td>
        <td><span class="badge badge-status-<%= user.active ? 'open' : 'closed' %>"><%= user.active ? 'Active' : 'Disabled' %></span></td>
        <td class="actions no-row-click">
          <% if (user.role !== 'admin') { %>
            <form action="/admin/users/<%= user.id %>/toggle" method="POST" class="inline-form">
              <button type="submit" class="btn btn-sm btn-ghost"><%= user.active ? 'Disable' : 'Enable' %></button>
            </form>
            <form action="/admin/users/<%= user.id %>/toggle-submissions" method="POST" class="inline-form">
              <label class="perm-toggle" title="<%= user.can_manage_submissions ? 'Revoke submissions access' : 'Grant submissions access' %>">
                <input type="checkbox" <%= user.can_manage_submissions ? 'checked' : '' %> onchange="this.form.submit()">
                <span class="perm-toggle-track"></span>
                Manage Submissions
              </label>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<script src="/js/admin-users.js"></script>

<%- include('../partials/footer') %>
