<%- include('../partials/header') %>

<div class="page-header">
  <h1>Manage Users</h1>
</div>

<div class="form-card" id="user-form-card">
  <h2 id="form-title">Add User</h2>
  <form id="user-form" action="/admin/users" method="POST" autocomplete="off">
    <input type="hidden" id="edit-id" name="edit_id" value="">
    <div class="form-row">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required autocomplete="off">
      </div>
      <div class="form-group">
        <label for="display_name">Display Name</label>
        <input type="text" id="display_name" name="display_name" required autocomplete="off">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="off">
      </div>
      <div class="form-group" id="password-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="new-password">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="role">Role</label>
        <select id="role" name="role">
          <option value="user">User</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <div class="form-group form-group-checkbox" id="submissions-group">
        <label class="checkbox-label">
          <input type="checkbox" id="can_manage_submissions" name="can_manage_submissions" value="1">
          <span class="checkbox-text">Manage Submissions</span>
        </label>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="form-submit">Create User</button>
      <button type="button" class="btn btn-ghost" id="cancel-edit" style="display:none;">Cancel</button>
      <button type="button" class="btn btn-danger" id="remove-user-btn" style="display:none;">Remove User</button>
    </div>
  </form>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Username</th>
      <th>Display Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(user => { %>
      <tr class="<%= user.active ? '' : 'row-muted' %>" style="cursor:pointer;"
          data-user-id="<%= user.id %>"
          data-username="<%= user.username %>"
          data-display-name="<%= user.display_name %>"
          data-email="<%= user.email %>"
          data-role="<%= user.role %>"
          data-can-manage-submissions="<%= user.can_manage_submissions ? '1' : '0' %>">
        <td><%= user.username %></td>
        <td><%= user.display_name %></td>
        <td><%= user.email %></td>
        <td><span class="badge"><%= user.role %></span></td>
        <td><span class="badge badge-status-<%= user.active ? 'open' : 'closed' %>"><%= user.active ? 'Active' : 'Disabled' %></span></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<div id="remove-user-modal" class="modal-overlay" style="display:none;">
  <div class="modal">
    <h3>Remove User</h3>
    <p>Are you sure you want to remove <strong id="remove-user-name"></strong>? This cannot be undone.</p>
    <form id="remove-user-form" method="POST">
      <div class="modal-actions">
        <button type="submit" class="btn btn-danger">Yes, Remove</button>
        <button type="button" class="btn btn-ghost" id="close-remove-modal">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/admin-users.js"></script>

<%- include('../partials/footer') %>
