<%- include('../partials/header') %>

<div class="page-header">
  <h1>Site Settings</h1>
</div>

<div class="form-card">
  <form action="/admin/settings" method="POST">
    <div class="form-group">
      <label for="tagline">Tagline</label>
      <input type="text" id="tagline" name="tagline" value="<%= settings.tagline || '' %>" placeholder="Shown on the landing page under the logo">
    </div>
    <div class="form-group">
      <label for="footer_text">Footer Text</label>
      <input type="text" id="footer_text" name="footer_text" value="<%= settings.footer_text || '' %>" placeholder="Copyright notice shown in the footer">
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="public_project_access" <%= settings.public_project_access === '1' ? 'checked' : '' %>> Allow public access to project details (when off, visitors see the project list but cannot open individual projects)
      </label>
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="show_report_bug_button" <%= settings.show_report_bug_button !== '0' ? 'checked' : '' %>> Show "Report a Bug" button on public pages
      </label>
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="show_request_feature_button" <%= settings.show_request_feature_button !== '0' ? 'checked' : '' %>> Show "Request a Feature" button on public pages
      </label>
    </div>
    <div class="form-group">
      <label class="form-label" style="margin-bottom:0.5rem; display:block; font-weight:600;">Table Columns</label>
      <p class="text-muted" style="font-size:0.85rem; margin-bottom:0.75rem;">Choose which columns are visible in the bugs, feature requests, and todos tables.</p>
      <label class="checkbox-label">
        <input type="checkbox" name="table_col_priority" <%= settings.table_col_priority !== '0' ? 'checked' : '' %>> Priority
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="table_col_status" <%= settings.table_col_status !== '0' ? 'checked' : '' %>> Status
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="table_col_assignee" <%= settings.table_col_assignee !== '0' ? 'checked' : '' %>> Assignee
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="table_col_created" <%= settings.table_col_created !== '0' ? 'checked' : '' %>> Created
      </label>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Settings</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
