<%- include('../partials/header') %>

<div class="page-header">
  <h1>Site Settings</h1>
</div>

<div class="form-card">
  <form action="/admin/settings" method="POST">
    <div class="form-group">
      <label for="tagline">Tagline</label>
      <input type="text" id="tagline" name="tagline" value="<%= settings.tagline || '' %>" placeholder="Shown on the landing page under the logo">
    </div>
    <div class="form-group">
      <label for="footer_text">Footer Text</label>
      <input type="text" id="footer_text" name="footer_text" value="<%= settings.footer_text || '' %>" placeholder="Copyright notice shown in the footer">
    </div>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="public_project_access" <%= settings.public_project_access === '1' ? 'checked' : '' %>> Allow public access to project details (when off, visitors see the project list but cannot open individual projects)
      </label>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Settings</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
