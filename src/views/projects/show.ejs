<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1><%= project.name %></h1>
    <% if (project.description) { %>
      <p class="text-muted"><%= project.description %></p>
    <% } %>
    <% if (project.homepage_url || (project.github_url && (currentUser || !project.github_private))) { %>
    <div class="project-links">
      <% if (project.homepage_url) { %>
        <a href="<%= project.homepage_url %>" target="_blank" class="project-link">Homepage</a>
      <% } %>
      <% if (project.github_url && (currentUser || !project.github_private)) { %>
        <a href="<%= project.github_url %>" target="_blank" class="project-link">GitHub</a>
      <% } %>
    </div>
    <% } %>
  </div>
  <% if (currentUser) { %>
    <div class="btn-group">
      <button type="button" class="btn btn-ghost" id="project-card-btn">Project Card</button>
      <a href="/bugs/new?project=<%= project.slug %>&type=todo" class="btn btn-todo">Add Todo</a>
      <a href="/bugs/new?project=<%= project.slug %>&type=feature" class="btn btn-feature">Request Feature</a>
      <a href="/bugs/new?project=<%= project.slug %>&type=bug" class="btn btn-primary">Report Bug</a>
    </div>
  <% } %>
</div>

<% if (currentUser) { %>
<div class="section-block section-todo">
  <div class="section-header">
    <h2>Todos</h2>
    <span class="section-counts">
      <a href="?show=open" class="count-tab<%= showStatus === 'open' ? ' count-tab-active' : '' %>"><%= todoCounts.open %> open</a>
      <a href="?show=closed" class="count-tab<%= showStatus === 'closed' ? ' count-tab-active' : '' %>"><%= todoCounts.closed %> closed</a>
    </span>
  </div>
  <% if (todos.length === 0) { %>
    <div class="empty-state"><p>No <%= showStatus %> todos.</p></div>
  <% } else { %>
    <table class="table" id="todos-table">
      <thead>
        <tr>
          <% if (showStatus === 'open') { %><th class="col-todo-num" data-sort="id">NUM</th><% } %>
          <th>Task</th>
          <% if (siteSettings.table_col_priority !== '0') { %><th class="col-priority" data-sort="priority">Priority</th><% } %>
          <% if (siteSettings.table_col_status !== '0') { %><th class="col-status" data-sort="status">Status</th><% } %>
          <% if (siteSettings.table_col_assignee !== '0') { %><th class="col-assignee">Assignee</th><% } %>
          <% if (siteSettings.table_col_created !== '0') { %><th class="col-date" data-sort="created">Created</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% todos.forEach((item, idx) => { %>
          <tr class="clickable-row<%= item.priority === 'critical' ? ' row-critical' : '' %>" data-href="/bugs/<%= item.id %>">
            <% if (showStatus === 'open') { %><td class="col-todo-num" data-col="id" data-sort="<%= idx + 1 %>">#<%= idx + 1 %></td><% } %>
            <td><a href="/bugs/<%= item.id %>"><%= item.title %></a></td>
            <% if (siteSettings.table_col_priority !== '0') { %><td class="col-priority" data-col="priority" data-sort="<%= item.priority %>"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td><% } %>
            <% if (siteSettings.table_col_status !== '0') { %><td class="col-status" data-col="status" data-sort="<%= item.status %>"><span class="badge badge-status-<%= item.status %>"><%= item.status === 'in_progress' ? 'in progress' : item.status %></span></td><% } %>
            <% if (siteSettings.table_col_assignee !== '0') { %><td class="col-assignee"><%= item.assignee_name || '—' %></td><% } %>
            <% if (siteSettings.table_col_created !== '0') { %><td class="col-date" data-col="created" data-sort="<%= item.created_at %>"><%= item.created_at.split('T')[0] %></td><% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<% } %>

<div class="section-block section-feature">
  <div class="section-header">
    <h2>Feature Requests</h2>
    <% if (currentUser) { %>
    <span class="section-counts">
      <a href="?show=open" class="count-tab<%= showStatus === 'open' ? ' count-tab-active' : '' %>"><%= featureCounts.open %> open</a>
      <a href="?show=closed" class="count-tab<%= showStatus === 'closed' ? ' count-tab-active' : '' %>"><%= featureCounts.closed %> closed</a>
    </span>
    <% } %>
  </div>
  <% if (features.length === 0) { %>
    <div class="empty-state"><p>No <%= showStatus %> feature requests.</p></div>
  <% } else { %>
    <table class="table" id="features-table">
      <thead>
        <tr>
          <th class="col-id" data-sort="id">REQ ID</th>
          <th>Title</th>
          <% if (siteSettings.table_col_priority !== '0') { %><th class="col-priority" data-sort="priority">Priority</th><% } %>
          <% if (siteSettings.table_col_status !== '0') { %><th class="col-status" data-sort="status">Status</th><% } %>
          <% if (siteSettings.table_col_assignee !== '0') { %><th class="col-assignee">Assignee</th><% } %>
          <% if (siteSettings.table_col_created !== '0') { %><th class="col-date" data-sort="created">Created</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% features.forEach(item => { %>
          <tr<% if (currentUser) { %> class="clickable-row<%= item.priority === 'critical' ? ' row-critical' : '' %>" data-href="/bugs/<%= item.id %>"<% } %>>
            <td class="col-id" data-col="id" data-sort="<%= item.display_number || 0 %>">REQ-<%= String(item.display_number || 0).padStart(3, '0') %></td>
            <td><% if (currentUser) { %><a href="/bugs/<%= item.id %>"><%= item.title %></a><% } else { %><%= item.title %><% } %></td>
            <% if (siteSettings.table_col_priority !== '0') { %><td class="col-priority" data-col="priority" data-sort="<%= item.priority %>"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td><% } %>
            <% if (siteSettings.table_col_status !== '0') { %><td class="col-status" data-col="status" data-sort="<%= item.status %>"><span class="badge badge-status-<%= item.status %>"><%= item.status === 'in_progress' ? 'in progress' : item.status %></span></td><% } %>
            <% if (siteSettings.table_col_assignee !== '0') { %><td class="col-assignee"><%= item.assignee_name || '—' %></td><% } %>
            <% if (siteSettings.table_col_created !== '0') { %><td class="col-date" data-col="created" data-sort="<%= item.created_at %>"><%= item.created_at.split('T')[0] %></td><% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="section-block section-bug">
  <div class="section-header">
    <h2>Bugs</h2>
    <% if (currentUser) { %>
    <span class="section-counts">
      <a href="?show=open" class="count-tab<%= showStatus === 'open' ? ' count-tab-active' : '' %> <%= bugCounts.open > 0 ? 'count-bugs-red' : 'count-bugs-green' %>"><%= bugCounts.open %> open</a>
      <a href="?show=closed" class="count-tab<%= showStatus === 'closed' ? ' count-tab-active' : '' %>"><%= bugCounts.closed %> closed</a>
    </span>
    <% } %>
  </div>
  <% if (bugs.length === 0) { %>
    <div class="empty-state"><p>No <%= showStatus %> bugs.</p></div>
  <% } else { %>
    <table class="table" id="bugs-table">
      <thead>
        <tr>
          <th class="col-id" data-sort="id">BUG ID</th>
          <th>Title</th>
          <% if (siteSettings.table_col_priority !== '0') { %><th class="col-priority" data-sort="priority">Priority</th><% } %>
          <% if (siteSettings.table_col_status !== '0') { %><th class="col-status" data-sort="status">Status</th><% } %>
          <% if (siteSettings.table_col_assignee !== '0') { %><th class="col-assignee">Assignee</th><% } %>
          <% if (siteSettings.table_col_created !== '0') { %><th class="col-date" data-sort="created">Created</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% bugs.forEach(item => { %>
          <tr<% if (currentUser) { %> class="clickable-row<%= item.priority === 'critical' ? ' row-critical' : '' %>" data-href="/bugs/<%= item.id %>"<% } %>>
            <td class="col-id" data-col="id" data-sort="<%= item.display_number || 0 %>">BUG-<%= String(item.display_number || 0).padStart(3, '0') %></td>
            <td><% if (currentUser) { %><a href="/bugs/<%= item.id %>"><%= item.title %></a><% } else { %><%= item.title %><% } %></td>
            <% if (siteSettings.table_col_priority !== '0') { %><td class="col-priority" data-col="priority" data-sort="<%= item.priority %>"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td><% } %>
            <% if (siteSettings.table_col_status !== '0') { %><td class="col-status" data-col="status" data-sort="<%= item.status %>"><span class="badge badge-status-<%= item.status %>"><%= item.status === 'in_progress' ? 'in progress' : item.status %></span></td><% } %>
            <% if (siteSettings.table_col_assignee !== '0') { %><td class="col-assignee"><%= item.assignee_name || '—' %></td><% } %>
            <% if (siteSettings.table_col_created !== '0') { %><td class="col-date" data-col="created" data-sort="<%= item.created_at %>"><%= item.created_at.split('T')[0] %></td><% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<% if (currentUser) { %>
<div class="section-block section-notes">
  <div class="section-header">
    <h2>Notes</h2>
    <button type="button" class="btn btn-sm btn-ghost" id="notes-edit-btn">Edit</button>
  </div>
  <div class="notes-display" id="notes-display">
    <% if (project.notes) { %>
      <pre class="notes-content"><%= project.notes %></pre>
    <% } else { %>
      <p class="text-muted">No notes yet. Click Edit to add notes.</p>
    <% } %>
  </div>
  <form action="/projects/<%= project.slug %>/notes" method="POST" id="notes-form" style="display:none;">
    <textarea id="notes-textarea" name="notes" rows="12" class="notes-editor"><%= project.notes || '' %></textarea>
    <div class="form-actions" style="margin-top:0.75rem;">
      <button type="submit" class="btn btn-primary btn-sm">Save</button>
      <button type="button" class="btn btn-ghost btn-sm" id="notes-cancel-btn">Cancel</button>
    </div>
  </form>
</div>
<% } %>

<div id="project-card-modal" class="modal-overlay" style="display:none;">
  <div class="modal modal-wide">
    <h3>Project Card — <%= project.name %></h3>
    <form action="/projects/summary/<%= project.id %>/card" method="POST">
      <input type="hidden" name="return_to" value="/projects/<%= project.slug %>">
      <div class="form-row">
        <div class="form-group">
          <label for="modal-nickname">Nickname</label>
          <input type="text" id="modal-nickname" name="nickname" value="<%= project.nickname || '' %>" placeholder="e.g. Baby Chorus">
        </div>
        <div class="form-group">
          <label for="modal-scope">Scope</label>
          <input type="text" id="modal-scope" name="scope" value="<%= project.scope || '' %>" placeholder="e.g. Programming Language">
        </div>
      </div>
      <div class="form-group">
        <label for="modal-purpose">Purpose</label>
        <textarea id="modal-purpose" name="purpose" rows="4" placeholder="Describe the project's purpose..."><%= project.purpose || '' %></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="modal-project-status">Status</label>
          <input type="text" id="modal-project-status" name="project_status" value="<%= project.project_status || '' %>" placeholder="e.g. Active (v0.9.1-alpha)">
        </div>
        <div class="form-group">
          <label for="modal-tags">Tags</label>
          <div class="tag-input-wrapper" data-target="modal-tags-hidden">
            <div class="tag-input-pills"></div>
            <input type="text" class="tag-input-text" placeholder="Type and press Enter">
          </div>
          <input type="hidden" id="modal-tags-hidden" name="tags" value="<%= project.tags || '' %>">
        </div>
      </div>
      <div class="modal-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-ghost" id="close-card-modal">Cancel</button>
      </div>
    </form>
  </div>
</div>

<div id="current-project" data-slug="<%= project.slug %>" data-name="<%= project.name %>" hidden></div>
<script src="/js/clickable-rows.js"></script>
<script src="/js/project-notes.js"></script>
<script src="/js/table-sort.js"></script>
<script src="/js/project-card.js"></script>

<%- include('../partials/footer') %>
