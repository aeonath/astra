<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1><%= project.name %></h1>
    <% if (project.description) { %>
      <p class="text-muted"><%= project.description %></p>
    <% } %>
  </div>
  <% if (currentUser) { %>
    <div class="btn-group">
      <a href="/bugs/new?project=<%= project.slug %>&type=todo" class="btn btn-todo">Add Todo</a>
      <a href="/bugs/new?project=<%= project.slug %>&type=feature" class="btn btn-feature">Request Feature</a>
      <a href="/bugs/new?project=<%= project.slug %>&type=bug" class="btn btn-primary">Report Bug</a>
    </div>
  <% } %>
</div>

<% if (currentUser) { %>
<div class="section-block section-todo">
  <div class="section-header">
    <h2>Todos</h2>
    <span class="section-counts">
      <a href="?show=open" class="count-tab<%= showStatus === 'open' ? ' count-tab-active' : '' %>"><%= todoCounts.open %> open</a>
      <a href="?show=closed" class="count-tab<%= showStatus === 'closed' ? ' count-tab-active' : '' %>"><%= todoCounts.closed %> closed</a>
    </span>
  </div>
  <% if (todos.length === 0) { %>
    <div class="empty-state"><p>No <%= showStatus %> todos.</p></div>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <% if (showStatus === 'open') { %><th class="col-todo-num">Task ID</th><% } %>
          <th>Task</th>
          <th class="col-priority">Priority</th>
          <th class="col-assignee">Assignee</th>
          <th class="col-date">Created</th>
        </tr>
      </thead>
      <tbody>
        <% todos.forEach((item, idx) => { %>
          <tr>
            <% if (showStatus === 'open') { %><td class="col-todo-num"><%= idx + 1 %>.</td><% } %>
            <td><a href="/bugs/<%= item.id %>"><%= item.title %></a></td>
            <td class="col-priority"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td>
            <td class="col-assignee"><%= item.assignee_name || '—' %></td>
            <td class="col-date"><%= item.created_at.split('T')[0] %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<% } %>

<div class="section-block section-feature">
  <div class="section-header">
    <h2>Feature Requests</h2>
    <span class="section-counts">
      <a href="?show=open" class="count-tab<%= showStatus === 'open' ? ' count-tab-active' : '' %>"><%= featureCounts.open %> open</a>
      <a href="?show=closed" class="count-tab<%= showStatus === 'closed' ? ' count-tab-active' : '' %>"><%= featureCounts.closed %> closed</a>
    </span>
  </div>
  <% if (features.length === 0) { %>
    <div class="empty-state"><p>No <%= showStatus %> feature requests.</p></div>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th class="col-id">ID</th>
          <th>Title</th>
          <th class="col-priority">Priority</th>
          <th class="col-status">Status</th>
          <th class="col-assignee">Assignee</th>
          <th class="col-date">Created</th>
        </tr>
      </thead>
      <tbody>
        <% features.forEach(item => { %>
          <tr>
            <td class="col-id">REQ-<%= String(item.display_number || 0).padStart(3, '0') %></td>
            <td><% if (currentUser) { %><a href="/bugs/<%= item.id %>"><%= item.title %></a><% } else { %><%= item.title %><% } %></td>
            <td class="col-priority"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td>
            <td class="col-status"><span class="badge badge-status-<%= item.status %>"><%= item.status %></span></td>
            <td class="col-assignee"><%= item.assignee_name || '—' %></td>
            <td class="col-date"><%= item.created_at.split('T')[0] %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="section-block section-bug">
  <div class="section-header">
    <h2>Bugs</h2>
    <span class="section-counts">
      <a href="?show=open" class="count-tab<%= showStatus === 'open' ? ' count-tab-active' : '' %>"><%= bugCounts.open %> open</a>
      <a href="?show=closed" class="count-tab<%= showStatus === 'closed' ? ' count-tab-active' : '' %>"><%= bugCounts.closed %> closed</a>
    </span>
  </div>
  <% if (bugs.length === 0) { %>
    <div class="empty-state"><p>No <%= showStatus %> bugs.</p></div>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th class="col-id">ID</th>
          <th>Title</th>
          <th class="col-priority">Priority</th>
          <th class="col-status">Status</th>
          <th class="col-assignee">Assignee</th>
          <th class="col-date">Created</th>
        </tr>
      </thead>
      <tbody>
        <% bugs.forEach(item => { %>
          <tr>
            <td class="col-id">BUG-<%= String(item.display_number || 0).padStart(3, '0') %></td>
            <td><% if (currentUser) { %><a href="/bugs/<%= item.id %>"><%= item.title %></a><% } else { %><%= item.title %><% } %></td>
            <td class="col-priority"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td>
            <td class="col-status"><span class="badge badge-status-<%= item.status %>"><%= item.status %></span></td>
            <td class="col-assignee"><%= item.assignee_name || '—' %></td>
            <td class="col-date"><%= item.created_at.split('T')[0] %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
