<%- include('../partials/header') %>

<div class="page-header">
  <h1>Projects Summary</h1>
</div>

<% if (projects.length === 0) { %>
  <div class="empty-state">
    <p>No active projects.</p>
  </div>
<% } else { %>

  <div class="summary-cards">
    <% projects.forEach(project => { %>
      <div class="summary-card" id="card-<%= project.id %>" data-project-id="<%= project.id %>" draggable="true">
        <div class="summary-card-layout">
          <div class="summary-card-drag-handle" title="Drag to reorder">&#9776;</div>
          <div class="summary-card-left">
            <div class="summary-card-display" id="card-display-<%= project.id %>">
              <div class="summary-card-header">
                <h2><a href="/projects/<%= project.slug %>"><%= project.name %></a></h2>
                <% if (project.nickname) { %>
                  <span class="summary-card-nickname">"<%= project.nickname %>"</span>
                <% } %>
                <button type="button" class="btn btn-sm btn-ghost summary-card-edit-btn" data-project-id="<%= project.id %>">Edit</button>
              </div>
              <div class="summary-card-body">
                <% if (project.scope) { %>
                  <div class="summary-card-field"><strong>Scope:</strong> <%= project.scope %></div>
                <% } %>
                <% if (project.purpose) { %>
                  <div class="summary-card-field"><strong>Purpose:</strong> <%= project.purpose %></div>
                <% } %>
                <% if (project.project_status) { %>
                  <div class="summary-card-field"><strong>Status:</strong> <span class="badge badge-project-status-<%= project.project_status.toLowerCase().replace(/\s+/g, '-') %>"><%= project.project_status %></span></div>
                <% } %>
                <% if (project.tags) { %>
                  <div class="tag-list">
                    <% project.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(tag => { %>
                      <span class="tag-pill"><%= tag %></span>
                    <% }) %>
                  </div>
                <% } %>
                <% if (!project.scope && !project.purpose && !project.project_status && !project.tags) { %>
                  <p class="text-muted">No project card details yet. Click Edit to add details.</p>
                <% } %>
              </div>
            </div>
            <div class="summary-card-form" id="card-form-<%= project.id %>" style="display:none;">
              <form action="/projects/summary/<%= project.id %>/card" method="POST">
                <input type="hidden" name="return_to" value="/projects/summary">
                <div class="summary-card-header">
                  <h2><%= project.name %></h2>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="nickname-<%= project.id %>">Nickname</label>
                    <input type="text" id="nickname-<%= project.id %>" name="nickname" value="<%= project.nickname || '' %>" placeholder="e.g. Baby Chorus">
                  </div>
                  <div class="form-group">
                    <label for="scope-<%= project.id %>">Scope</label>
                    <input type="text" id="scope-<%= project.id %>" name="scope" value="<%= project.scope || '' %>" placeholder="e.g. Programming Language (Core Development)">
                  </div>
                </div>
                <div class="form-group">
                  <label for="purpose-<%= project.id %>">Purpose</label>
                  <textarea id="purpose-<%= project.id %>" name="purpose" rows="3" placeholder="Describe the project's purpose..."><%= project.purpose || '' %></textarea>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="project_status-<%= project.id %>">Status</label>
                    <select id="project_status-<%= project.id %>" name="project_status">
                      <option value="">— Select —</option>
                      <option value="Planning" <%= project.project_status === 'Planning' ? 'selected' : '' %>>Planning</option>
                      <option value="In Development" <%= project.project_status === 'In Development' ? 'selected' : '' %>>In Development</option>
                      <option value="Maintenance" <%= project.project_status === 'Maintenance' ? 'selected' : '' %>>Maintenance</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="tags-<%= project.id %>">Tags</label>
                    <div class="tag-input-wrapper" data-target="tags-hidden-<%= project.id %>">
                      <div class="tag-input-pills"></div>
                      <input type="text" class="tag-input-text" placeholder="Type and press Enter">
                    </div>
                    <input type="hidden" id="tags-hidden-<%= project.id %>" name="tags" value="<%= project.tags || '' %>">
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn btn-primary btn-sm">Save</button>
                  <button type="button" class="btn btn-ghost btn-sm summary-card-cancel-btn" data-project-id="<%= project.id %>">Cancel</button>
                </div>
              </form>
            </div>
          </div>
          <div class="summary-card-right">
            <div class="summary-notes-header">
              <label>Notes</label>
              <span class="summary-notes-status" id="notes-status-<%= project.id %>"></span>
            </div>
            <textarea class="summary-notes-textarea" id="summary-notes-<%= project.id %>" data-project-id="<%= project.id %>" placeholder="Add notes..."><%= project.summary_notes || '' %></textarea>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <h2 class="category-heading" style="margin-top: 2rem;">Project Overview</h2>

  <table class="table">
    <thead>
      <tr>
        <th>Project</th>
        <th>Nickname</th>
        <th>Category</th>
        <th>Assignee</th>
        <th>Status</th>
        <th>Bugs</th>
        <th>Features</th>
        <th>Todos</th>
      </tr>
    </thead>
    <tbody>
      <% projects.forEach(project => { %>
        <tr>
          <td><a href="/projects/<%= project.slug %>"><%= project.name %></a></td>
          <td class="text-muted"><%= project.nickname || '—' %></td>
          <td><%= project.category_name || '—' %></td>
          <td><%= project.assignee_name || '—' %></td>
          <td><% if (project.project_status) { %><span class="badge badge-project-status-<%= project.project_status.toLowerCase().replace(/\s+/g, '-') %>"><%= project.project_status %></span><% } else { %>—<% } %></td>
          <td><span class="stat-num <%= project.open_bugs > 0 ? 'stat-bug' : '' %>"><%= project.open_bugs %></span></td>
          <td><span class="stat-num"><%= project.open_features %></span></td>
          <td><span class="stat-num <%= project.open_todos > 0 ? 'stat-todo-warn' : '' %>"><%= project.open_todos %></span></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

<% } %>

<script src="/js/project-card.js"></script>

<%- include('../partials/footer') %>
