<%- include('../partials/header') %>

<div class="page-header">
  <h1>Projects</h1>
</div>

<% if (projects.length === 0) { %>
  <div class="empty-state">
    <p>No projects yet.</p>
    <% if (isAdmin) { %>
      <a href="/admin/projects" class="btn btn-primary">Create a Project</a>
    <% } %>
  </div>
<% } else { %>
  <div class="project-grid">
    <% projects.forEach(project => { %>
      <a href="/projects/<%= project.slug %>" class="project-card">
        <h2><%= project.name %></h2>
        <% if (project.description) { %>
          <p class="project-desc"><%= project.description %></p>
        <% } %>
        <div class="project-stats">
          <span class="stat stat-bug">
            <span class="stat-num"><%= project.open_bugs %></span> open bugs
          </span>
          <span class="stat stat-feature">
            <span class="stat-num"><%= project.open_features %></span> open features
          </span>
          <% if (currentUser) { %>
          <span class="stat stat-todo">
            <span class="stat-num"><%= project.open_todos %></span> open todos
          </span>
          <% } %>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
