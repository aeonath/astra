<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <div class="breadcrumb">
      <a href="/projects/<%= bug.project_slug %>"><%= bug.project_name %></a>
      <span>&rsaquo;</span>
      <span><%= bug.type === 'feature' ? 'Feature' : bug.type === 'todo' ? 'Todo' : 'Bug' %> #<%= bug.id %></span>
    </div>
    <h1 id="bug-title-display"><span class="badge badge-type-<%= bug.type %>"><%= bug.type === 'feature' ? 'Feature' : bug.type === 'todo' ? 'Todo' : 'Bug' %></span> <%= bug.title %></h1>
  </div>
  <button type="button" class="btn btn-sm btn-ghost" id="edit-btn">Edit</button>
</div>

<div class="bug-layout">
  <div class="bug-main">
    <div id="bug-display">
      <div class="bug-description card">
        <% if (bug.description) { %>
          <p id="bug-desc-text"><%= bug.description %></p>
        <% } else { %>
          <p id="bug-desc-text" class="text-muted">No description provided.</p>
        <% } %>
      </div>
    </div>

    <form action="/bugs/<%= bug.id %>" method="POST" id="bug-edit-form" style="display:none;">
      <div class="card" style="margin-bottom:1rem;">
        <div class="form-group">
          <label for="edit-title">Title</label>
          <input type="text" id="edit-title" name="title" value="<%= bug.title %>" required>
        </div>
        <div class="form-group">
          <label for="edit-description">Description</label>
          <textarea id="edit-description" name="description" rows="6"><%= bug.description || '' %></textarea>
        </div>
        <input type="hidden" name="status" value="<%= bug.status %>">
        <input type="hidden" name="priority" value="<%= bug.priority %>">
        <input type="hidden" name="assignee_id" value="<%= bug.assignee_id || '' %>">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-sm">Save</button>
          <button type="button" class="btn btn-ghost btn-sm" id="cancel-edit-btn">Cancel</button>
        </div>
      </div>
    </form>

    <div class="comments-section">
      <h2>Comments (<%= comments.length %>)</h2>

      <% if (comments.length === 0) { %>
        <p class="text-muted">No comments yet.</p>
      <% } %>

      <% comments.forEach(comment => { %>
        <div class="comment card">
          <div class="comment-header">
            <strong><%= comment.author_name %></strong>
            <span class="text-muted"><%= comment.created_at %></span>
          </div>
          <p><%= comment.content %></p>
        </div>
      <% }) %>

      <form action="/bugs/<%= bug.id %>/comment" method="POST" class="comment-form">
        <div class="form-group">
          <textarea name="content" rows="3" placeholder="Add a comment..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Add Comment</button>
      </form>
    </div>
  </div>

  <aside class="bug-sidebar">
    <form action="/bugs/<%= bug.id %>" method="POST" class="card sidebar-form">
      <h3>Details</h3>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status">
          <% ['open', 'closed'].forEach(s => { %>
            <option value="<%= s %>" <%= bug.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="priority">Priority</label>
        <select id="priority" name="priority">
          <% ['low', 'medium', 'high', 'critical'].forEach(p => { %>
            <option value="<%= p %>" <%= bug.priority === p ? 'selected' : '' %>><%= p %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="assignee_id">Assignee</label>
        <select id="assignee_id" name="assignee_id">
          <option value="">Unassigned</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= bug.assignee_id === u.id ? 'selected' : '' %>><%= u.display_name %></option>
          <% }) %>
        </select>
      </div>

      <input type="hidden" name="title" value="<%= bug.title %>">
      <input type="hidden" name="description" value="<%= bug.description || '' %>">

      <button type="submit" class="btn btn-primary btn-sm btn-block">Update</button>

      <div class="sidebar-meta">
        <p><strong>Type:</strong> <%= bug.type === 'feature' ? 'Feature Request' : bug.type === 'todo' ? 'Todo Item' : 'Bug Report' %></p>
        <p><strong>Reporter:</strong> <%= bug.reporter_name %></p>
        <p><strong>Created:</strong> <%= bug.created_at %></p>
        <p><strong>Updated:</strong> <%= bug.updated_at %></p>
      </div>
    </form>
  </aside>
</div>

<script src="/js/bug-edit.js"></script>

<%- include('../partials/footer') %>
