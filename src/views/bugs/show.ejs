<%- include('../partials/header') %>

<div class="breadcrumb">
  <a href="/projects/<%= bug.project_slug %>">Project &mdash; <%= bug.project_name %></a>
  <span>&rsaquo;</span>
  <span><%= displayId %></span>
  <span class="badge badge-type-<%= bug.type %>"><%= bug.type === 'feature' ? 'Feature Request' : bug.type === 'todo' ? 'Todo' : 'Bug' %></span>
  <span id="status-badge" class="badge badge-status-<%= bug.status %>"><%= bug.status === 'in_progress' ? 'in progress' : bug.status %></span>
  <span id="priority-badge" class="badge badge-<%= bug.priority %>"><%= bug.priority %></span>
</div>

<% if (bug.type === 'todo') { %>
<h2 class="task-number-heading"><%= displayId %></h2>
<% } %>

<div class="bug-layout<%= bug.status === 'closed' ? ' bug-is-closed' : '' %><%= bug.priority === 'critical' ? ' bug-priority-critical' : '' %>">
  <div class="bug-main">
    <h2 style="margin-bottom: 0.75rem;"><%= bug.type === 'todo' ? 'Task:' : 'Description:' %></h2>

    <div class="card card-editable" id="description-display" style="margin-bottom: 1.25rem;">
      <p id="bug-title-display"><%= bug.title %></p>
      <button type="button" class="btn btn-sm btn-ghost card-edit-btn" id="description-edit-btn">Edit</button>
    </div>

    <form action="/bugs/<%= bug.id %>" method="POST" id="description-edit-form" class="card" style="display:none; margin-bottom: 1.25rem;">
      <div class="form-group">
        <% if (bug.type === 'todo') { %>
          <textarea name="title" rows="2" required><%= bug.title %></textarea>
        <% } else { %>
          <input type="text" name="title" value="<%= bug.title %>" required>
        <% } %>
      </div>
      <input type="hidden" name="description" value="<%= bug.description || '' %>">
      <input type="hidden" name="status" value="<%= bug.status %>">
      <input type="hidden" name="priority" value="<%= bug.priority %>">
      <input type="hidden" name="assignee_id" value="<%= bug.assignee_id || '' %>">
      <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-sm">Save</button>
        <button type="button" class="btn btn-ghost btn-sm" id="description-cancel-btn">Cancel</button>
      </div>
    </form>

    <% if (bug.type !== 'todo') { %>
      <h2 style="margin-bottom: 0.75rem;">Additional Notes:</h2>

      <div class="card card-editable" id="notes-display" style="margin-bottom: 1.25rem;">
        <% if (bug.description) { %>
          <p id="bug-desc-text" style="white-space: pre-wrap; font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', 'Cascadia Code', Consolas, monospace;"><%= bug.description %></p>
        <% } else { %>
          <p id="bug-desc-text" class="text-muted">No additional notes.</p>
        <% } %>
        <button type="button" class="btn btn-sm btn-ghost card-edit-btn" id="notes-edit-btn">Edit</button>
      </div>

      <form action="/bugs/<%= bug.id %>" method="POST" id="notes-edit-form" class="card" style="display:none; margin-bottom: 1.25rem;">
        <div class="form-group">
          <textarea name="description" rows="6" style="font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', 'Cascadia Code', Consolas, monospace;"><%= bug.description || '' %></textarea>
        </div>
        <input type="hidden" name="title" value="<%= bug.title %>">
        <input type="hidden" name="status" value="<%= bug.status %>">
        <input type="hidden" name="priority" value="<%= bug.priority %>">
        <input type="hidden" name="assignee_id" value="<%= bug.assignee_id || '' %>">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-sm">Save</button>
          <button type="button" class="btn btn-ghost btn-sm" id="notes-cancel-btn">Cancel</button>
        </div>
      </form>
    <% } %>

    <div class="comments-section">
      <h2>Comments: (<%= comments.length %>)</h2>

      <% if (comments.length === 0) { %>
        <p class="text-muted">No comments yet.</p>
      <% } %>

      <% comments.forEach(comment => { %>
        <div class="comment card">
          <div class="comment-header">
            <div>
              <strong><%= comment.author_name %></strong>
              <span class="text-muted"><%= comment.created_at %></span>
            </div>
            <div class="comment-actions">
              <button type="button" class="btn btn-sm btn-ghost comment-edit-btn" data-comment-id="<%= comment.id %>">Edit</button>
              <% if (isAdmin) { %>
                <form action="/bugs/<%= bug.id %>/comment/<%= comment.id %>/delete" method="POST" class="inline-form">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this comment?')">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
          <div id="comment-display-<%= comment.id %>">
            <p><%= comment.content %></p>
          </div>
          <form id="comment-edit-form-<%= comment.id %>" action="/bugs/<%= bug.id %>/comment/<%= comment.id %>/edit" method="POST" style="display:none;">
            <div class="form-group" style="margin-top:0.5rem;">
              <textarea name="content" rows="3" required><%= comment.content %></textarea>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary btn-sm">Save</button>
              <button type="button" class="btn btn-ghost btn-sm comment-cancel-btn" data-comment-id="<%= comment.id %>">Cancel</button>
            </div>
          </form>
        </div>
      <% }) %>

      <form action="/bugs/<%= bug.id %>/comment" method="POST" class="comment-form">
        <div class="form-group">
          <textarea name="content" rows="3" placeholder="Add a comment..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Add Comment</button>
      </form>
    </div>

    <% if (bug.type === 'bug') { %>
    <div class="files-section">
      <h2>Attachments: (<%= files.length %>)</h2>

      <% if (files.length === 0) { %>
        <p class="text-muted" style="margin-bottom: 1rem;">No attachments yet.</p>
      <% } else { %>
        <% files.forEach(f => { %>
          <div class="file-item card">
            <a href="/bugs/<%= bug.id %>/files/<%= encodeURIComponent(f.filename) %>" class="file-name"><%= f.filename %></a>
            <span class="file-meta text-muted"><%= f.size ? (f.size / 1024).toFixed(1) + ' KB' : '' %><%= f.uploader_name ? ' · ' + f.uploader_name : '' %> · <%= f.uploaded_at.split('T')[0] %></span>
          </div>
        <% }) %>
      <% } %>

      <form action="/bugs/<%= bug.id %>/files" method="POST" enctype="multipart/form-data" class="file-upload-form">
        <div class="file-upload-row">
          <button type="submit" class="btn btn-sm btn-primary">Attach</button>
          <input type="file" name="file" id="file-input" required>
        </div>
      </form>
    </div>
    <% } %>
  </div>

  <aside class="bug-sidebar">
    <form action="/bugs/<%= bug.id %>" method="POST" class="card sidebar-form">
      <h3>Details</h3>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" name="status">
          <% ['open', 'in_progress', 'closed'].forEach(s => { %>
            <option value="<%= s %>" <%= bug.status === s ? 'selected' : '' %>><%= s === 'in_progress' ? 'in progress' : s %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="priority">Priority</label>
        <select id="priority" name="priority" <%= bug.status === 'closed' ? 'disabled' : '' %>>
          <% ['low', 'medium', 'high', 'critical'].forEach(p => { %>
            <option value="<%= p %>" <%= bug.priority === p ? 'selected' : '' %>><%= p %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="assignee_id">Assignee</label>
        <select id="assignee_id" name="assignee_id" <%= bug.status === 'closed' ? 'disabled' : '' %>>
          <option value="">Unassigned</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= bug.assignee_id === u.id ? 'selected' : '' %>><%= u.display_name %></option>
          <% }) %>
        </select>
      </div>

      <input type="hidden" name="title" value="<%= bug.title %>">
      <input type="hidden" name="description" value="<%= bug.description || '' %>">

      <button type="submit" class="btn btn-primary btn-block">Update</button>

      <div class="sidebar-meta">
        <p><strong>Type:</strong> <span class="badge badge-type-<%= bug.type %>"><%= bug.type === 'feature' ? 'Feature Request' : bug.type === 'todo' ? 'Todo' : 'Bug' %></span></p>
        <p><strong>ID:</strong> <%= displayId %></p>
        <p><strong>Reporter:</strong> <%= bug.reporter_name %></p>
        <p><strong>Created:</strong> <%= bug.created_at %></p>
        <p><strong>Updated:</strong> <%= bug.updated_at %></p>
      </div>
    </form>
  </aside>
</div>

<div id="current-project" data-slug="<%= bug.project_slug %>" data-name="<%= bug.project_name %>" hidden></div>
<script src="/js/bug-edit.js"></script>

<%- include('../partials/footer') %>
