<%- include('../partials/header') %>

<div class="page-header">
  <h1>Search</h1>
</div>

<div class="advanced-search-card">
  <form action="/bugs/search" method="GET" id="search-form">
    <div class="search-row search-row-main">
      <div class="form-group search-text-group">
        <input type="text" name="q" value="<%= q %>" placeholder="Search title and description..." autofocus>
      </div>
      <div class="search-actions">
        <button type="submit" class="btn btn-primary">Search</button>
        <a href="#" class="btn btn-ghost" id="advanced-toggle">Advanced ▾</a>
        <% if (hasAdvancedFilter) { %>
          <a href="/bugs/search<%= q ? '?q=' + encodeURIComponent(q) : '' %>" class="btn btn-ghost">Clear filters</a>
        <% } %>
      </div>
    </div>

    <div id="advanced-panel" style="display:none;">
      <div class="search-row" style="margin-top:0.75rem;">
        <div class="form-group">
          <label>Type</label>
          <select name="type">
            <option value="">Any type</option>
            <option value="bug"     <%= typeFilter === 'bug'     ? 'selected' : '' %>>Bug</option>
            <option value="feature" <%= typeFilter === 'feature' ? 'selected' : '' %>>Feature Request</option>
            <option value="todo"    <%= typeFilter === 'todo'    ? 'selected' : '' %>>Todo</option>
          </select>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="">Any status</option>
            <option value="open"        <%= statusFilter === 'open'        ? 'selected' : '' %>>Open</option>
            <option value="in_progress" <%= statusFilter === 'in_progress' ? 'selected' : '' %>>In Progress</option>
            <option value="closed"      <%= statusFilter === 'closed'      ? 'selected' : '' %>>Closed</option>
          </select>
        </div>
        <div class="form-group">
          <label>Priority</label>
          <select name="priority">
            <option value="">Any priority</option>
            <option value="critical" <%= priorityFilter === 'critical' ? 'selected' : '' %>>Critical</option>
            <option value="high"     <%= priorityFilter === 'high'     ? 'selected' : '' %>>High</option>
            <option value="medium"   <%= priorityFilter === 'medium'   ? 'selected' : '' %>>Medium</option>
            <option value="low"      <%= priorityFilter === 'low'      ? 'selected' : '' %>>Low</option>
          </select>
        </div>
        <div class="form-group">
          <label>Project</label>
          <select name="project">
            <option value="">Any project</option>
            <% projects.forEach(p => { %>
              <option value="<%= p.slug %>" <%= projectSlug === p.slug ? 'selected' : '' %>><%= p.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Assignee</label>
          <select name="assignee">
            <option value="">Any assignee</option>
            <option value="unassigned" <%= assigneeId === 'unassigned' ? 'selected' : '' %>>Unassigned</option>
            <% users.forEach(u => { %>
              <option value="<%= u.id %>" <%= assigneeId === String(u.id) ? 'selected' : '' %>><%= u.display_name %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>
  </form>
</div>

<% if (results.length === 0 && hasAnyFilter) { %>
  <p class="text-muted">No results for <% if (q) { %>"<strong><%= q %></strong>"<% } %><% if (hasAdvancedFilter) { %> with the selected filters<% } %>.</p>
<% } else { %>
  <%
    const filterParts = [];
    if (typeFilter)     filterParts.push(typeFilter === 'feature' ? 'Feature Request' : typeFilter === 'todo' ? 'Todo' : 'Bug');
    if (statusFilter)   filterParts.push(statusFilter === 'in_progress' ? 'In Progress' : statusFilter.charAt(0).toUpperCase() + statusFilter.slice(1));
    if (priorityFilter) filterParts.push(priorityFilter.charAt(0).toUpperCase() + priorityFilter.slice(1) + ' priority');
    if (projectSlug)    { const p = projects.find(p => p.slug === projectSlug); if (p) filterParts.push(p.name); }
    if (assigneeId === 'unassigned') filterParts.push('Unassigned');
    else if (assigneeId) { const u = users.find(u => String(u.id) === assigneeId); if (u) filterParts.push(u.display_name); }
  %>
  <div class="search-summary">
    <span><strong><%= results.length %></strong> result<%= results.length !== 1 ? 's' : '' %><% if (q) { %> for "<%= q %>"<% } %></span>
    <% if (filterParts.length) { %>
      <span class="search-filter-tags">
        <% filterParts.forEach(f => { %><span class="search-filter-tag"><%= f %></span><% }) %>
      </span>
    <% } %>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th class="col-id">ID</th>
        <th>Title</th>
        <th class="col-priority">Type</th>
        <th class="col-priority">Priority</th>
        <th class="col-status">Status</th>
        <th class="col-assignee">Project</th>
        <th class="col-date">Created</th>
      </tr>
    </thead>
    <tbody>
      <% results.forEach(item => { %>
        <% const prefixes = { bug: 'BUG', feature: 'REQ' }; %>
        <% const prefix = prefixes[item.type]; %>
        <% const displayId = prefix && item.display_number ? prefix + '-' + String(item.display_number).padStart(3, '0') : item.type === 'todo' ? 'Todo' : '#' + item.id; %>
        <tr class="clickable-row<%= item.priority === 'critical' ? ' row-critical' : '' %>" data-href="/bugs/<%= item.id %>">
          <td class="col-id"><%= displayId %></td>
          <td><a href="/bugs/<%= item.id %>"><%= item.title %></a></td>
          <td class="col-priority"><span class="badge badge-type-<%= item.type %>"><%= item.type === 'feature' ? 'Feature Request' : item.type === 'todo' ? 'Todo' : 'Bug' %></span></td>
          <td class="col-priority"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td>
          <td class="col-status"><span class="badge badge-status-<%= item.status %>"><%= item.status === 'in_progress' ? 'in progress' : item.status %></span></td>
          <td class="col-assignee"><a href="/projects/<%= item.project_slug %>"><%= item.project_name %></a></td>
          <td class="col-date"><%= item.created_at.split('T')[0] %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<script src="/js/search-toggle.js"></script>
<script src="/js/clickable-rows.js"></script>
<%- include('../partials/footer') %>
