<%- include('../partials/header') %>

<div class="page-header">
  <h1>Search Results</h1>
</div>

<form action="/bugs/search" method="GET" class="search-form-page">
  <div class="search-input-group">
    <input type="text" name="q" value="<%= q %>" placeholder="Search bugs, features, todos..." autofocus>
    <% if (projectSlug) { %>
      <input type="hidden" name="project" value="<%= projectSlug %>">
    <% } %>
    <button type="submit" class="btn btn-primary">Search</button>
  </div>
  <% if (projectSlug && projectName) { %>
    <p class="text-muted" style="margin-top:0.5rem;">Searching in <strong><%= projectName %></strong> &mdash; <a href="/bugs/search?q=<%= encodeURIComponent(q) %>">search all projects</a></p>
  <% } %>
</form>

<% if (q && results.length === 0) { %>
  <div class="empty-state"><p>No results found for "<%= q %>"<%= projectName ? ' in ' + projectName : '' %>.</p></div>
<% } else if (results.length > 0) { %>
  <p class="text-muted"><%= results.length %> result<%= results.length !== 1 ? 's' : '' %> for "<%= q %>"<%= projectName ? ' in ' + projectName : '' %></p>
  <table class="table">
    <thead>
      <tr>
        <th class="col-id">ID</th>
        <th>Title</th>
        <th class="col-priority">Type</th>
        <th class="col-priority">Priority</th>
        <th class="col-status">Status</th>
        <th class="col-assignee">Project</th>
        <th class="col-date">Created</th>
      </tr>
    </thead>
    <tbody>
      <% results.forEach(item => { %>
        <% const prefixes = { bug: 'BUG', feature: 'REQ' }; %>
        <% const prefix = prefixes[item.type]; %>
        <% const displayId = prefix && item.display_number ? prefix + '-' + String(item.display_number).padStart(3, '0') : item.type === 'todo' ? 'Todo' : '#' + item.id; %>
        <tr class="clickable-row" data-href="/bugs/<%= item.id %>">
          <td class="col-id"><%= displayId %></td>
          <td><a href="/bugs/<%= item.id %>"><%= item.title %></a></td>
          <td class="col-priority"><span class="badge badge-type-<%= item.type %>"><%= item.type === 'feature' ? 'Feature' : item.type === 'todo' ? 'Todo' : 'Bug' %></span></td>
          <td class="col-priority"><span class="badge badge-<%= item.priority %>"><%= item.priority %></span></td>
          <td class="col-status"><span class="badge badge-status-<%= item.status %>"><%= item.status === 'in_progress' ? 'in progress' : item.status %></span></td>
          <td class="col-assignee"><a href="/projects/<%= item.project_slug %>"><%= item.project_name %></a></td>
          <td class="col-date"><%= item.created_at.split('T')[0] %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<script src="/js/clickable-rows.js"></script>

<%- include('../partials/footer') %>
