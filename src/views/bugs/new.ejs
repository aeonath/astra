<%- include('../partials/header') %>

<div class="page-header">
  <h1><%= issueType === 'feature' ? 'Request Feature' : 'Report Bug' %> &mdash; <%= project.name %></h1>
</div>

<form action="/bugs" method="POST" class="form-card">
  <input type="hidden" name="project_id" value="<%= project.id %>">
  <input type="hidden" name="type" value="<%= issueType %>">

  <div class="form-group">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required placeholder="<%= issueType === 'feature' ? 'Short summary of the feature' : 'Short summary of the bug' %>">
  </div>

  <div class="form-group">
    <label for="description">Description</label>
    <textarea id="description" name="description" rows="6" placeholder="<%= issueType === 'feature' ? 'Describe the feature, use case, and expected behavior...' : 'Steps to reproduce, expected vs actual behavior...' %>"></textarea>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="priority">Priority</label>
      <select id="priority" name="priority">
        <option value="low">Low</option>
        <option value="medium" selected>Medium</option>
        <option value="high">High</option>
        <option value="critical">Critical</option>
      </select>
    </div>

    <div class="form-group">
      <label for="assignee_id">Assignee</label>
      <select id="assignee_id" name="assignee_id">
        <option value="">Unassigned</option>
        <% users.forEach(u => { %>
          <option value="<%= u.id %>"><%= u.display_name %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn <%= issueType === 'feature' ? 'btn-feature' : 'btn-primary' %>">Submit <%= issueType === 'feature' ? 'Feature' : 'Bug' %></button>
    <a href="/projects/<%= project.slug %><%= issueType === 'feature' ? '?view=features' : '' %>" class="btn btn-ghost">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
