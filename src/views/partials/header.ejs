<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Astra<%= siteSettings.tagline ? ' | ' + siteSettings.tagline : '' %></title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% if (currentUser) { %>
  <nav class="navbar">
    <div class="nav-brand">
      <span>&#9733; Astra</span>
    </div>
    <div class="nav-links">
      <a href="/projects" class="<%= currentPath.startsWith('/projects') ? 'active' : '' %>">Projects</a>
      <% if (canManageSubmissions) { %>
        <a href="/submissions" class="<%= currentPath.startsWith('/submissions') ? 'active' : '' %>">Submissions</a>
      <% } %>
      <% if (isAdmin) { %>
        <a href="/admin" class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>">Admin</a>
      <% } %>
    </div>
    <div class="nav-user">
      <span class="user-name"><%= currentUser.display_name %></span>
      <form action="/logout" method="POST" class="inline-form">
        <button type="submit" class="btn btn-sm btn-ghost">Logout</button>
      </form>
    </div>
  </nav>
  <% } else { %>
  <div class="public-header">
    <% if (currentPath !== '/') { %>
      <a href="/" class="public-brand">&#9733; Astra</a>
    <% } else { %>
      <span></span>
    <% } %>
    <a href="/login" class="btn btn-sm btn-primary">Log In</a>
  </div>
  <% } %>

  <main class="container">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %>">
        <%= flash.message %>
      </div>
    <% } %>
