<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Astra<%= siteSettings.tagline ? ' | ' + siteSettings.tagline : '' %></title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <% if (currentUser) { %><meta name="astra-user-id" content="<%= currentUser.id %>"><% } %>
  <script src="/js/project-tabs.js"></script>
  <% if (canManageSubmissions) { %><script src="/js/admin-notifications.js"></script><% } %>
</head>
<body>
  <% if (currentUser) { %>
  <nav class="navbar">
    <div class="nav-brand">
      <span>&#9733; Astra</span>
    </div>
    <div class="nav-main">
      <div class="nav-links">
        <% if (!isAdmin) { %><a href="/projects" class="<%= currentPath === '/projects' ? 'active' : '' %>">Projects</a><% } %>
        <% if (canManageSubmissions) { %>
          <a href="/submissions" class="<%= currentPath.startsWith('/submissions') ? 'active' : '' %> nav-submissions">Submissions <span id="submissions-badge" class="submissions-badge" style="display:none;"></span></a>
        <% } %>
        <% if (isAdmin) { %>
          <a href="/admin" class="<%= currentPath.startsWith('/admin') ? 'active' : '' %>">Admin</a>
        <% } %>
      </div>
      <div id="project-tabs" class="project-tabs-container"></div>
    </div>
    <div class="nav-user">
      <form action="/bugs/search" method="GET" class="nav-search">
        <input type="text" name="q" placeholder="Search..." class="nav-search-input">
        <% if (typeof project !== 'undefined' && project && project.slug) { %>
          <input type="hidden" name="project" value="<%= project.slug %>">
        <% } %>
        <button type="submit" class="btn btn-sm btn-ghost nav-search-btn">Search</button>
      </form>
      <a href="/profile" class="user-name"><%= currentUser.display_name %></a>
      <form action="/logout" method="POST" class="inline-form">
        <button type="submit" class="btn btn-sm btn-ghost">Logout</button>
      </form>
    </div>
  </nav>
  <% } else { %>
  <div class="public-header">
    <div class="public-header-left">
      <% if (currentPath !== '/') { %>
        <a href="/" class="public-brand">&#9733; Astra</a>
      <% } %>
      <% if (currentPath !== '/login') { %>
        <% if (siteSettings.show_report_bug_button !== '0') { %>
          <a href="/projects/submit?type=bug<%= typeof project !== 'undefined' && project ? '&category_id=' + (project.category_id || '') + '&project_id=' + project.id : '' %>" class="btn btn-sm btn-primary">Report a Bug</a>
        <% } %>
        <% if (siteSettings.show_request_feature_button !== '0') { %>
          <a href="/projects/submit?type=feature<%= typeof project !== 'undefined' && project ? '&category_id=' + (project.category_id || '') + '&project_id=' + project.id : '' %>" class="btn btn-sm btn-feature">Request a Feature</a>
        <% } %>
      <% } %>
    </div>
    <% if (currentPath !== '/login') { %>
      <a href="/login" class="btn btn-sm btn-primary">Log In</a>
    <% } %>
  </div>
  <% } %>

  <main class="container">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %>">
        <%= flash.message %>
      </div>
    <% } %>
