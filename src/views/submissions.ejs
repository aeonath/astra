<%- include('partials/header') %>

<div class="page-header">
  <h1>Submissions</h1>
</div>

<% if (submissions.length === 0) { %>
  <div class="empty-state">
    <p>No submissions yet.</p>
  </div>
<% } else { %>
<table class="table">
  <thead>
    <tr>
      <th>Type</th>
      <th>Project</th>
      <th>Submitter</th>
      <th>Summary</th>
      <th>Status</th>
      <th>Date</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% submissions.forEach(sub => { %>
      <tr class="<%= sub.status === 'dismissed' ? 'row-muted' : '' %> submission-row" style="cursor:pointer;" data-detail="detail-<%= sub.id %>">
        <td><span class="badge badge-type-<%= sub.type %>"><%= sub.type === 'feature' ? 'Feature' : 'Bug' %></span></td>
        <td><%= sub.project_name %></td>
        <td>
          <%= sub.name %>
          <% if (sub.email) { %>
            <br><span class="text-muted" style="font-size:0.8rem;"><%= sub.email %></span>
          <% } %>
        </td>
        <td>
          <strong><%= sub.title %></strong>
          <% if (sub.description) { %>
            <br><span class="text-muted" style="font-size:0.85rem;"><%= sub.description.length > 120 ? sub.description.substring(0, 120) + '...' : sub.description %></span>
          <% } %>
        </td>
        <td><span class="badge badge-status-<%= sub.status === 'new' ? 'open' : 'closed' %>"><%= sub.status %></span></td>
        <td class="col-date"><%= sub.created_at %></td>
        <td class="actions no-row-click">
          <% if (sub.imported_bug_id) { %>
            <% const impPrefix = sub.type === 'bug' ? 'BUG' : 'REQ'; %>
            <a href="/bugs/<%= sub.imported_bug_id %>" class="btn btn-sm btn-ghost"><%= impPrefix %>-<%= String(sub.imported_display_number).padStart(3, '0') %></a>
          <% } else { %>
            <form action="/submissions/<%= sub.id %>/import" method="POST" class="inline-form">
              <button type="submit" class="btn btn-sm btn-primary">Import</button>
            </form>
          <% } %>
          <% if (sub.status === 'new' && !sub.imported_bug_id) { %>
            <form action="/submissions/<%= sub.id %>/status" method="POST" class="inline-form">
              <input type="hidden" name="status" value="reviewed">
              <button type="submit" class="btn btn-sm btn-ghost">Review</button>
            </form>
            <form action="/submissions/<%= sub.id %>/status" method="POST" class="inline-form">
              <input type="hidden" name="status" value="dismissed">
              <button type="submit" class="btn btn-sm btn-danger">Dismiss</button>
            </form>
          <% } else if (sub.status === 'reviewed' && !sub.imported_bug_id) { %>
            <form action="/submissions/<%= sub.id %>/status" method="POST" class="inline-form">
              <input type="hidden" name="status" value="dismissed">
              <button type="submit" class="btn btn-sm btn-danger">Dismiss</button>
            </form>
          <% } else if (sub.status === 'dismissed' && !sub.imported_bug_id) { %>
            <form action="/submissions/<%= sub.id %>/status" method="POST" class="inline-form">
              <input type="hidden" name="status" value="new">
              <button type="submit" class="btn btn-sm btn-ghost">Reopen</button>
            </form>
          <% } %>
        </td>
      </tr>
      <tr class="submission-detail" id="detail-<%= sub.id %>" style="display:none;">
        <td colspan="7">
          <div class="submission-detail-content">
            <p><strong>Submitter:</strong> <%= sub.name %><% if (sub.email) { %> &lt;<%= sub.email %>&gt;<% } %></p>
            <p><strong>Summary:</strong> <%= sub.title %></p>
            <% if (sub.description) { %>
              <p><strong>Details:</strong></p>
              <p class="submission-detail-text"><%= sub.description %></p>
            <% } else { %>
              <p class="text-muted">No additional details provided.</p>
            <% } %>
          </div>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
<% } %>

<script src="/js/submissions.js"></script>

<%- include('partials/footer') %>
