<%- include('partials/header') %>

<div class="landing-header">
  <h1>&#9733; Astra</h1>
  <p class="text-muted">Bug Tracker &mdash; MiraNova Studios</p>
  <% if (!currentUser) { %>
    <a href="/login" class="btn btn-primary">Log In</a>
  <% } %>
</div>

<% if (projects.length === 0) { %>
  <div class="empty-state">
    <p>No projects yet.</p>
  </div>
<% } else { %>
  <div class="project-summary-grid">
    <% projects.forEach(project => { %>
      <a href="/projects/<%= project.slug %>" class="project-summary-card">
        <h2><%= project.name %></h2>
        <% if (project.description) { %>
          <p class="project-desc"><%= project.description %></p>
        <% } %>
        <div class="summary-stats">
          <div class="summary-stat summary-open">
            <span class="summary-num"><%= project.open_count %></span>
            <span class="summary-label">Open</span>
          </div>
          <div class="summary-stat summary-in-progress">
            <span class="summary-num"><%= project.in_progress_count %></span>
            <span class="summary-label">In Progress</span>
          </div>
          <div class="summary-stat summary-resolved">
            <span class="summary-num"><%= project.resolved_count %></span>
            <span class="summary-label">Resolved</span>
          </div>
          <div class="summary-stat summary-closed">
            <span class="summary-num"><%= project.closed_count %></span>
            <span class="summary-label">Closed</span>
          </div>
        </div>
        <div class="summary-total"><%= project.total_count %> total</div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
