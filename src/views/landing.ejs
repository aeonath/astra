<%- include('partials/header') %>

<div class="landing-header">
  <h1>&#9733; Astra</h1>
  <p class="text-muted"><%= siteSettings.tagline || '' %></p>
</div>

<% if (projects.length === 0) { %>
  <div class="empty-state">
    <p>No projects yet.</p>
  </div>
<% } else { %>
  <% categories.forEach(cat => { %>
    <% const catProjects = projects.filter(p => p.category_id === cat.id); %>
    <% if (catProjects.length > 0) { %>
      <h2 class="category-heading"><%= cat.name %></h2>
      <div class="project-summary-grid">
        <% catProjects.forEach(project => { %>
          <a href="/projects/<%= project.slug %>" class="project-summary-card">
            <h2><%= project.name %></h2>
            <% if (project.description) { %>
              <p class="project-desc"><%= project.description %></p>
            <% } %>
            <div class="summary-stats">
              <div class="summary-stat summary-bugs">
                <span class="summary-num"><%= project.open_bugs %></span>
                <span class="summary-label">Open Bugs</span>
              </div>
              <div class="summary-stat summary-features">
                <span class="summary-num"><%= project.open_features %></span>
                <span class="summary-label">Feature Requests</span>
              </div>
              <% if (currentUser) { %>
              <div class="summary-stat summary-todos">
                <span class="summary-num"><%= project.open_todos %></span>
                <span class="summary-label">Open Todos</span>
              </div>
              <% } %>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  <% }) %>

  <% const uncategorized = projects.filter(p => !p.category_id); %>
  <% if (uncategorized.length > 0) { %>
    <h2 class="category-heading">Other</h2>
    <div class="project-summary-grid">
      <% uncategorized.forEach(project => { %>
        <a href="/projects/<%= project.slug %>" class="project-summary-card">
          <h2><%= project.name %></h2>
          <% if (project.description) { %>
            <p class="project-desc"><%= project.description %></p>
          <% } %>
          <div class="summary-stats">
            <div class="summary-stat summary-bugs">
              <span class="summary-num"><%= project.open_bugs %></span>
              <span class="summary-label">Open Bugs</span>
            </div>
            <div class="summary-stat summary-features">
              <span class="summary-num"><%= project.open_features %></span>
              <span class="summary-label">Feature Requests</span>
            </div>
            <% if (currentUser) { %>
            <div class="summary-stat summary-todos">
              <span class="summary-num"><%= project.open_todos %></span>
              <span class="summary-label">Open Todos</span>
            </div>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
<% } %>

<%- include('partials/footer') %>
