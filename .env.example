PORT=9000
HOST=localhost
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# Database path (REQUIRED, must be absolute)
# Production example: DB_PATH=/var/lib/astra/astra.db
# Dev example (Linux): DB_PATH=/home/you/astra-data/astra.db
# Dev example (Windows): DB_PATH=C:/Work/astra/data/astra.db
DB_PATH=/var/lib/astra/astra.db

# Session database directory (optional, defaults to same directory as DB_PATH)
# SESSION_DB_DIR=/var/lib/astra

# File attachments directory (REQUIRED for bug file uploads, must be absolute)
# Production example: FILES_DIR=/var/lib/astra/files
# Dev example (Windows): FILES_DIR=C:/Work/astra/files
FILES_DIR=/var/lib/astra/files

# Google reCAPTCHA v2 (optional — if not set, reCAPTCHA widget is hidden and verification is skipped)
# Register keys at https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
